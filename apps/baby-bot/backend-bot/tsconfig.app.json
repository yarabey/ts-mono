{
  "compilerOptions": {
    "outDir": "dist",
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2021"],
    "module": "commonjs",
    "moduleResolution": "node10",
    "noEmitOnError": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2021",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@acme/baby-bot-domain": ["../../../libs/baby-bot/domain/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"],
  "references": [
    {
      "path": "../../../libs/baby-bot/domain"
    }
  ]
}
