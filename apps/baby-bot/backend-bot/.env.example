# --- Database -------------------------------------------------------------
# Local dev Postgres from docker-compose (baby-bot-postgres, host port 5433)
DATABASE_URL="postgresql://baby_bot:baby_bot@localhost:5433/baby_bot?schema=public"

# --- Server ---------------------------------------------------------------
PORT=3100

# --- Auth -----------------------------------------------------------------
JWT_SECRET="change-me-in-production"
ACCESS_CODE="123456"

# --- Telegram -------------------------------------------------------------
TELEGRAM_BOT_TOKEN=""
# Optional SOCKS5 proxy for reaching the Telegram API (host:port or full url)
TELEGRAM_SOCKS5_PROXY=""
# Public URL the bot menu button opens (the deployed mini-app)
MINI_APP_URL=""

# --- AI / transcription ---------------------------------------------------
# OpenAI key used for Whisper voice transcription
OPENAI_API_KEY=""
# ZAI / GLM endpoint used by the raw-entry parser (OpenAI-compatible;
# the service appends `/chat/completions`). For the GLM Coding Plan
# (international) use the coding base below — NOT `/v1` and NOT the Anthropic URL.
ZAI_API_KEY=""
ZAI_BASE_URL="https://api.z.ai/api/coding/paas/v4"
ZAI_MODEL="glm-4.6"

# --- Filesystem paths -----------------------------------------------------
DATA_DIR="./data"
CSV_DIR="./csv"
REALM_DIR="./data/realm"
UPLOADS_DIR="./data/uploads"

# --- Feature flags --------------------------------------------------------
# Write a markdown diary file per raw entry (parity with original baby-ai)
MARKDOWN_DIARY_ENABLED="false"
