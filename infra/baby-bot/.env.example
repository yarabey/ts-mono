# baby-bot PRODUCTION environment.
#
# This file documents the contents of the `BABY_BOT_ENV` GitHub Actions secret.
# The deploy workflow writes the secret verbatim to `.env` on the server and then
# APPENDS `REGISTRY` and `IMAGE_TAG` — so do NOT put REGISTRY/IMAGE_TAG in the
# secret. Never commit a real `.env`.

# --- Edge / TLS -----------------------------------------------------------
# Public domain whose DNS A-record points at the server. Caddy obtains a
# Let's Encrypt cert for it (HTTP-01 on :80) and serves the app on :8443.
DOMAIN="bot.example.com"

# --- Database -------------------------------------------------------------
# `postgres` is the compose service name; port 5432 is internal to the network.
# The DATABASE_URL password MUST equal POSTGRES_PASSWORD.
POSTGRES_USER="baby_bot"
POSTGRES_PASSWORD="change-me-strong-random"
POSTGRES_DB="baby_bot"
DATABASE_URL="postgresql://baby_bot:change-me-strong-random@postgres:5432/baby_bot?schema=public"

# --- Auth -----------------------------------------------------------------
JWT_SECRET="change-me-strong-random"
ACCESS_CODE="123456"

# --- Telegram -------------------------------------------------------------
TELEGRAM_BOT_TOKEN="123456:your-token-from-botfather"
# Optional SOCKS5 proxy for reaching the Telegram API (leave empty if direct).
TELEGRAM_SOCKS5_PROXY=""
# The URL the bot menu button opens (the deployed mini-app under /mini-app/).
MINI_APP_URL="https://bot.example.com:8443/mini-app/"

# --- AI / transcription ---------------------------------------------------
# Optional: OpenAI key for Whisper voice transcription (empty disables it).
OPENAI_API_KEY=""
# Optional: GLM key for raw-entry parsing (empty disables AI parsing).
# ZAI_BASE_URL is OpenAI-compatible; the service appends `/chat/completions`.
# For the international GLM Coding Plan use the coding base below
# (NOT `/v1`, and NOT the Anthropic `/api/anthropic` endpoint).
ZAI_API_KEY=""
ZAI_BASE_URL="https://api.z.ai/api/coding/paas/v4"
ZAI_MODEL="glm-4.6"

# --- Filesystem -----------------------------------------------------------
# Persisted via the `babybot-data` volume.
DATA_DIR="/app/data"

# --- Backups (pg-backup sidecar) -----------------------------------------
# All optional — the sidecar falls back to these defaults if unset. Dumps land
# in /opt/baby-bot/backups on the host; the offsite copy to the Finnish server
# is a separate host-cron job (see infra/README.md + backup-offsite.sh).
# SCHEDULE is a cron expression or one of @hourly/@daily/@weekly/@monthly.
BACKUP_SCHEDULE="@daily"
BACKUP_KEEP_DAYS="7"
BACKUP_KEEP_WEEKS="4"
BACKUP_KEEP_MONTHS="6"
# Timezone the SCHEDULE is evaluated in (e.g. Europe/Helsinki). Defaults to UTC.
TZ="UTC"
